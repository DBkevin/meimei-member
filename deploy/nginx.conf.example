server {
    listen 80;
    # Replace your-domain.com with your real production domain.
    server_name your-domain.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    # Replace your-domain.com with your real production domain.
    server_name your-domain.com;

    # Replace certificate paths with your real certificate files.
    ssl_certificate      /etc/nginx/ssl/your-domain.com.pem;
    ssl_certificate_key  /etc/nginx/ssl/your-domain.com.key;

    root /opt/meimei-member/web/dist;
    index index.html;

    location /api/ {
        # The backend keeps system.router-prefix: "", so Nginx strips /api before proxying.
        rewrite ^/api/?(.*)$ /$1 break;
        proxy_pass http://127.0.0.1:8888;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
